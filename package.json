{
  "name": "lens-engine",
  "version": "0.1.0",
  "type": "module",
  "description": "Multi-representation programming: keep prose intent artifacts in sync with each other and with the code",
  "author": "Zenbase AI",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyrusNuevoDia/lens.git"
  },
  "homepage": "https://github.com/CyrusNuevoDia/lens",
  "keywords": [
    "lens",
    "cli",
    "llm",
    "ai",
    "sync",
    "content-addressed",
    "prose-first"
  ],
  "bin": {
    "lens": "dist/lens.js"
  },
  "files": [
    "dist/lens.js",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "embed-templates": "bun scripts/embed-templates.ts",
    "build": "bun run embed-templates && bun build src/index.ts --outfile dist/lens.js --target node --minify",
    "build:bin": "bun run embed-templates && bun build src/index.ts --compile --outfile bin/lens",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@types/bun": "latest",
    "fast-glob": "^3.3.3",
    "shescape": "^2.1.8",
    "strip-json-comments": "^5.0.3",
    "typescript": "^5.9.0",
    "ultracite": "7.1.4",
    "yaml": "^2.6.0",
    "zod": "^4.3.6"
  }
}
